NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Hanya di server (API admin). Jangan diprefix NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Untuk npm run db:migrate — URI dari Dashboard → Database → Connection string (Postgres password).
DATABASE_URL=

# Alternatif migrasi: cukup password DB + NEXT_PUBLIC_SUPABASE_URL (ref di-parse).
# SUPABASE_DB_PASSWORD=
# SUPABASE_PROJECT_REF=your_project_ref
